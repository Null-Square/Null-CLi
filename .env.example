# Null AI CLI — model configuration
# Copy to `.env` (git-ignored) and fill in. NEVER commit real keys or targets.

# OpenAI-compatible API key. Leave empty to force offline dry-run mode.
NULL_AI_API_KEY=

# Optional: override the OpenAI-compatible base URL (e.g. a local gateway).
# NULL_AI_BASE_URL=https://api.openai.com/v1

# Model id used for live assessments.
NULL_AI_MODEL=gpt-4.1-mini

# Only ever point assessments at systems you own or are authorized to test.
# Example, safe-to-share placeholder target (RFC 2606 reserved domain):
# NULL_AI_EXAMPLE_TARGET=https://app.acme.example
