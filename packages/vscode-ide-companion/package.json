{
    "name":  "null-cli-vscode-companion",
    "displayName":  "Null CLI Companion",
    "description":  "Enable Null CLI with direct access to your VS Code workspace.",
    "version":  "0.0.10",
    "publisher":  "nullsec",
    "icon":  "assets/icon.png",
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/QwenLM/qwen-code.git",
                       "directory":  "packages/vscode-ide-companion"
                   },
    "engines":  {
                    "vscode":  "^1.99.0"
                },
    "license":  "LICENSE",
    "preview":  true,
    "categories":  [
                       "AI"
                   ],
    "keywords":  [
                     "null-cli",
                     "null",
                     "cli",
                     "ide integration",
                     "ide companion"
                 ],
    "activationEvents":  [
                             "onStartupFinished"
                         ],
    "contributes":  {
                        "languages":  [
                                          {
                                              "id":  "null-diff-editable"
                                          }
                                      ],
                        "commands":  [
                                         {
                                             "command":  "null.diff.accept",
                                             "title":  "Null CLI: Accept Current Diff",
                                             "icon":  "$(check)"
                                         },
                                         {
                                             "command":  "null.diff.cancel",
                                             "title":  "Null CLI: Close Diff Editor",
                                             "icon":  "$(close)"
                                         },
                                         {
                                             "command":  "null.runNull",
                                             "title":  "Null CLI: Run"
                                         },
                                         {
                                             "command":  "null.showNotices",
                                             "title":  "Null CLI: View Third-Party Notices"
                                         }
                                     ],
                        "menus":  {
                                      "commandPalette":  [
                                                             {
                                                                 "command":  "null.diff.accept",
                                                                 "when":  "null.diff.isVisible"
                                                             },
                                                             {
                                                                 "command":  "null.diff.cancel",
                                                                 "when":  "null.diff.isVisible"
                                                             }
                                                         ],
                                      "editor/title":  [
                                                           {
                                                               "command":  "null.diff.accept",
                                                               "when":  "null.diff.isVisible",
                                                               "group":  "navigation"
                                                           },
                                                           {
                                                               "command":  "null.diff.cancel",
                                                               "when":  "null.diff.isVisible",
                                                               "group":  "navigation"
                                                           }
                                                       ]
                                  },
                        "keybindings":  [
                                            {
                                                "command":  "null.diff.accept",
                                                "key":  "ctrl+s",
                                                "when":  "null.diff.isVisible"
                                            },
                                            {
                                                "command":  "null.diff.accept",
                                                "key":  "cmd+s",
                                                "when":  "null.diff.isVisible"
                                            }
                                        ]
                    },
    "main":  "./dist/extension.cjs",
    "type":  "module",
    "scripts":  {
                    "pretest": "pnpm --filter @null/null-core build",
                    "vscode:prepublish":  "npm run generate:notices \u0026\u0026 npm run check-types \u0026\u0026 npm run lint \u0026\u0026 node esbuild.js --production",
                    "build":  "npm run compile",
                    "compile":  "npm run check-types \u0026\u0026 npm run lint \u0026\u0026 node esbuild.js",
                    "watch":  "npm-run-all -p watch:*",
                    "watch:esbuild":  "node esbuild.js --watch",
                    "watch:tsc":  "tsc --noEmit --watch --project tsconfig.json",
                    "package":  "vsce package --no-dependencies",
                    "generate:notices":  "node ./scripts/generate-notices.js",
                    "check-types":  "tsc --noEmit",
                    "lint":  "eslint src",
                    "test":  "vitest run",
                    "test:ci":  "vitest run --coverage"
                },
    "devDependencies":  {
                            "@null/null-core":  "file:../core",
                            "@types/cors":  "^2.8.19",
                            "@types/express":  "^5.0.3",
                            "@types/node":  "20.x",
                            "@types/vscode":  "^1.99.0",
                            "@typescript-eslint/eslint-plugin":  "^8.31.1",
                            "@typescript-eslint/parser":  "^8.31.1",
                            "esbuild":  "^0.25.3",
                            "eslint":  "^9.25.1",
                            "npm-run-all":  "^4.1.5",
                            "typescript":  "^5.8.3",
                            "vitest":  "^3.2.4"
                        },
    "dependencies":  {
                         "@modelcontextprotocol/sdk":  "^1.15.1",
                         "cors":  "^2.8.5",
                         "express":  "^5.1.0",
                         "zod":  "^3.25.76"
                     }
}
